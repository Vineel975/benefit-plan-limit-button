-- Check Ruleconfiguration columns
SELECT COLUMN_NAME 
FROM INFORMATION_SCHEMA.COLUMNS 
WHERE TABLE_NAME = 'Ruleconfiguration'
ORDER BY ORDINAL_POSITION

-- Check BPSIConditions columns  
SELECT COLUMN_NAME 
FROM INFORMATION_SCHEMA.COLUMNS 
WHERE TABLE_NAME = 'BPSIConditions'
ORDER BY ORDINAL_POSITION

-- Check Mst_BPConditions columns
SELECT COLUMN_NAME 
FROM INFORMATION_SCHEMA.COLUMNS 
WHERE TABLE_NAME = 'Mst_BPConditions'
ORDER BY ORDINAL_POSITION

-- Check conditions configured for BPSIID = 436675
SELECT rc.*, c.Name AS ConditionName, c.ParentID
FROM Ruleconfiguration rc WITH(NOLOCK)
LEFT JOIN Mst_BPConditions c WITH(NOLOCK) ON c.ID = rc.BPConditionID
WHERE rc.BPSIID = 436675
ORDER BY c.Name

-- Also check BPSIConditions for this BPSIID
SELECT bsc.*, c.Name AS ConditionName
FROM BPSIConditions bsc WITH(NOLOCK)
LEFT JOIN Mst_BPConditions c WITH(NOLOCK) ON c.ID = bsc.ConditionID
WHERE bsc.BPSIID = 436675
ORDER BY c.Name

-- Check what Mst_BPConditions looks like
SELECT TOP 10 * FROM Mst_BPConditions WITH(NOLOCK)
ORDER BY ID


-- Find all BP related tables in the DB
SELECT TABLE_NAME 
FROM INFORMATION_SCHEMA.TABLES 
WHERE TABLE_NAME LIKE 'BP%'
ORDER BY TABLE_NAME

-- Also check
SELECT TABLE_NAME 
FROM INFORMATION_SCHEMA.TABLES 
WHERE TABLE_NAME LIKE '%Condition%'
OR TABLE_NAME LIKE '%RuleConfig%'
OR TABLE_NAME LIKE '%BenefitPlan%'
ORDER BY TABLE_NAME

-- Get BPSIID for this member policy
SELECT TOP 1 ID, BPSIID, MemberPolicyID, SIAmount, SITypeID
FROM MemberSI WITH(NOLOCK)
WHERE MemberPolicyID = 94539527
AND ISNULL(Deleted, 0) = 0
ORDER BY ID DESC

-- Then check what rules exist for this BPSIID
-- Replace <BPSIID> with the value from above
SELECT rc.*, c.Name AS ConditionName
FROM BPRuleConfig rc WITH(NOLOCK)
LEFT JOIN BPMasterCondition c WITH(NOLOCK) ON c.ID = rc.BPConditionID
WHERE rc.BPSIID = <BPSIID>
ORDER BY c.Name


-- 1. Check what conditions are configured for this member policy's benefit plan
EXEC USP_BPSumInsured_Retrieve

-- 2. Check ClaimsCoding for procedure used
SELECT TOP 5 
    ID, ClaimID, SlNo,
    TPAProcedureID, TPALevel1, TPALevel2, TPALevel3,
    CreatedDatetime
FROM ClaimsCoding WITH(NOLOCK)
WHERE ClaimID = 26041586026
ORDER BY ID DESC

-- 3. Check what BPSIID is linked to MemberPolicy 94539527
SELECT ID, BenefitPlanID, MemberPolicyID, SIAmount, SITypeID
FROM BPSumInsured WITH(NOLOCK)
WHERE ID = (
    SELECT TOP 1 BPSIID 
    FROM MemberPolicy WITH(NOLOCK) 
    WHERE ID = 94539527
)

-- 4. Check what rules exist for this BPSIID
SELECT rc.*, c.Name AS ConditionName
FROM BPRuleConfig rc WITH(NOLOCK)
JOIN BPMasterCondition c WITH(NOLOCK) ON c.ID = rc.BPConditionID
WHERE rc.BPSIID = (
    SELECT TOP 1 BPSIID 
    FROM MemberPolicy WITH(NOLOCK) 
    WHERE ID = 94539527
)
ORDER BY c.Name
